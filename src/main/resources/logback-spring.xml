<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Common pattern ─────────────────────────────────────────────────── -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ── Dev profile: console at WARN, app code at INFO ──────────────── -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

        <!-- App code at INFO — only our logs + errors -->
        <logger name="com.schedy" level="INFO"/>
        <!-- Silence framework noise -->
        <logger name="org.hibernate"          level="WARN"/>
        <logger name="org.hibernate.SQL"      level="WARN"/>
        <logger name="org.springframework"    level="WARN"/>
        <logger name="com.zaxxer.hikari"      level="WARN"/>
    </springProfile>

    <!-- ── Prod profile: console WARN + rolling file ──────────────────────── -->
    <springProfile name="prod">
        <!--
          SEC-07 / V33-bis SEC : structured JSON logs for SIEM/log-aggregator ingestion.
          Each line is a single JSON object containing @timestamp, level, logger, thread,
          message + every MDC key (orgId/userId/requestId once added). Kibana/Datadog/Loki
          can index these directly without regex parsing. Includes audit log entries
          (audit.creneau.update from PlanningService.java:177) as structured events.

          Tradeoff vs v32 plain text :
          + grep/jq friendly post-incident
          + audit log entries become structured
          + future MDC enrichment works with no encoder change
          - human readability degrades at the console (use jq locally if needed)
        -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>orgId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <customFields>{"app":"schedy","env":"prod"}</customFields>
            </encoder>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/schedy.log</file>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>orgId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <customFields>{"app":"schedy","env":"prod"}</customFields>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- Daily rollover, keep 30 days -->
                <fileNamePattern>logs/schedy.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <timeBasedFileNamingAndTriggeringPolicy
                        class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                    <maxFileSize>10MB</maxFileSize>
                </timeBasedFileNamingAndTriggeringPolicy>
                <maxHistory>30</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>

        <!-- Keep application logs at INFO in prod -->
        <logger name="com.schedy" level="INFO"/>
        <!-- Silence noisy framework logs in prod -->
        <logger name="org.hibernate"          level="WARN"/>
        <logger name="org.springframework"    level="WARN"/>
    </springProfile>

    <!-- ── Default (no profile active): same as dev ───────────────────────── -->
    <springProfile name="!dev &amp; !prod">
        <appender name="CONSOLE_DEFAULT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE_DEFAULT"/>
        </root>
    </springProfile>

</configuration>
