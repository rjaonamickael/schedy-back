# ══════════════════════════════════════════════════════════════
# Schedy Backend — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Database ──
DB_URL=jdbc:postgresql://localhost:5432/schedydb
DB_USERNAME=postgres
DB_PASSWORD=root

# ── JWT ──
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── Mail (Brevo SMTP) ──
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-login@smtp-brevo.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM=your-email@example.com

# ── Kiosk ──
# 6+ digit code recommended
KIOSK_ADMIN_CODE=2580

# ── TOTP 2FA ──
# Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Server ──
SERVER_PORT=8083
SPRING_PROFILES_ACTIVE=dev

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Frontend URL (for email links) ──
FRONTEND_URL=http://localhost:4200

# ══════════════════════════════════════════════════════════════
# Cloudflare R2 (S3-compatible object storage)
# ──────────────────────────────────────────────────────────────
# Used for testimonial logo uploads (sanitized SVGs only).
# Create a bucket in the Cloudflare dashboard, enable public
# access (or map a custom domain), then generate a scoped
# "Object Read & Write" API token.
#
# Dev uploads are namespaced under "dev/" automatically via the
# dev profile override — no need to override R2_PREFIX_LOGOS.
# ══════════════════════════════════════════════════════════════
R2_ENDPOINT=https://58ab3db69c80344fc178fd403387fa3b.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=schedy-public
R2_PUBLIC_URL_BASE=https://cdn.schedy.work
R2_REGION=auto
# Override only if you want a different object-key prefix than the default.
#   dev  profile default: dev/assets/logos-org
#   prod profile default: assets/logos-org
# R2_PREFIX_LOGOS=assets/logos-org
